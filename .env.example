# =========================================================================
# DATABASE CONFIGURATION TEMPLATE
# =========================================================================
# INSTRUCTIONS FOR COLLABORATORS:
# 1. Copy this file (.env.example) and rename the copy to ".env" in this directory.
# 2. Open the newly created ".env" file and replace "your_password_here" 
#    with your own local PostgreSQL database password.
# 3. Modify host, user, port, or database name if they differ on your setup.
# 4. NEVER commit or push the ".env" file to GitHub. (It is already in .gitignore).
# =========================================================================

ATTENDANCE_DB_HOST=localhost
ATTENDANCE_DB_NAME=attendance2
ATTENDANCE_DB_USER=postgres
ATTENDANCE_DB_PASSWORD=your_password_here
ATTENDANCE_DB_PORT=5432
